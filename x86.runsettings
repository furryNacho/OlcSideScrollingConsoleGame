<?xml version="1.0" encoding="utf-8"?>
<!-- Kör testvärdprocessen som x86 (32-bit).
     Krävs eftersom PenguinAfterAll.csproj har PlatformTarget=x86 p.g.a. SlimDX.dll
     som är ett 32-bitars native bibliotek. En 64-bitars testvärd kan inte ladda
     x86-assemblys och ger BadImageFormatException vid testkörning.

     Aktivera i Visual Studio via:
     Test → Configure Run Settings → Select Solution Wide runsettings File
     och peka på den här filen. -->
<RunSettings>
  <RunConfiguration>
    <TargetPlatform>x86</TargetPlatform>
  </RunConfiguration>
</RunSettings>
